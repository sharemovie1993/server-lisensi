datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id        String    @id
  name      String
  prefix    String    @unique
  plans     Plan[]
  licenses  License[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("products")
}

model Plan {
  id            String    @id
  productId     String    @map("product_id")
  product       Product   @relation(fields: [productId], references: [id])
  name          String
  priceMonthly  Float     @map("price_monthly")
  priceYearly   Float     @map("price_yearly")
  deviceLimit   Int       @map("device_limit")
  featuresJson  Json      @map("features_json")
  billingPeriod String    @map("billing_period")
  isActive      Boolean   @default(true) @map("is_active")
  moduleId      String?   @map("module_id")
  serviceCode   String?   @map("service_code")
  licenses      License[]
  invoices      Invoice[]
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("plans")
}

model License {
  id            String         @id @default(uuid())
  licenseKey    String         @unique @map("license_key")
  productId     String         @map("product_id")
  product       Product        @relation(fields: [productId], references: [id])
  schoolName    String         @map("school_name")
  deviceLimit   Int            @map("device_limit")
  isUnlimited   Int            @map("is_unlimited")
  expiresAt     String         @map("expires_at")
  status        String         @default("pending")
  isActive      Int            @default(0) @map("is_active")
  planId        String?        @map("plan_id")
  plan          Plan?          @relation(fields: [planId], references: [id])
  requestedSlug            String?        @map("requested_slug")
  requestedSupabaseUrl     String?        @map("requested_supabase_url")
  requestedSupabaseAnonKey String?        @map("requested_supabase_anon_key")
  wireguardIp              String?        @map("wireguard_ip")
  includeVpn               Int            @default(0) @map("include_vpn")
  customDomain             String?        @map("custom_domain")
  localPort                Int?           @map("local_port")
  appName                  String?        @map("app_name")
  operatorPhone            String?        @map("operator_phone")
  activeHostname           String?        @map("active_hostname")
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")
  subscriptions            Subscription[]
  invoices                 Invoice[]
  logs                     ActivityLog[]
  activatedDevices         ActivatedDevice[]

  @@map("licenses")
}

model ActivatedDevice {
  id          Int      @id @default(autoincrement())
  licenseId   String   @map("license_id")
  license     License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  deviceId    String   @map("device_id")
  activatedAt DateTime @default(now()) @map("activated_at")

  @@unique([licenseId, deviceId])
  @@map("activated_devices")
}

model Subscription {
  id         String   @id @default(uuid())
  licenseId  String   @map("license_id")
  license    License  @relation(fields: [licenseId], references: [id])
  schoolName String   @map("school_name")
  productId  String   @map("product_id")
  planId     String   @map("plan_id")
  status     String   @default("pending")
  startDate  String   @map("start_date")
  endDate    String   @map("end_date")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model Invoice {
  id                  String    @id @default(uuid())
  invoiceNumber       String    @unique @map("invoice_number")
  licenseId           String    @map("license_id")
  license             License   @relation(fields: [licenseId], references: [id])
  schoolName          String    @map("school_name")
  productId           String    @map("product_id")
  planTitle           String    @map("plan_title")
  amount              Float
  status              String    @default("unpaid")
  paymentMethod       String    @map("payment_method")
  paymentInstructions Json?     @map("payment_instructions")
  paymentProof        String?   @map("payment_proof")
  expiredTime         String    @map("expired_time")
  paidAt              DateTime? @map("paid_at")
  planId              String?   @map("plan_id")
  plan                Plan?     @relation(fields: [planId], references: [id])
  createdAt           DateTime  @default(now()) @map("created_at")

  @@map("invoices")
}

model ActivityLog {
  id         String   @id @default(uuid())
  licenseKey String   @map("license_key")
  license    License  @relation(fields: [licenseKey], references: [licenseKey])
  productId  String   @map("product_id")
  ipAddress  String   @map("ip_address")
  action     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}

model SystemSetting {
  key   String @id
  value String

  @@map("system_settings")
}
