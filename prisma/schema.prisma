generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String    @id
  name      String
  prefix    String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  licenses  License[]
  plans     Plan[]

  @@map("products")
}

model Plan {
  id            String    @id
  productId     String    @map("product_id")
  name          String
  priceMonthly  Float     @map("price_monthly")
  priceYearly   Float     @map("price_yearly")
  deviceLimit   Int       @map("device_limit")
  featuresJson  Json      @map("features_json")
  billingPeriod String    @map("billing_period")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  moduleId      String?   @map("module_id")
  serviceCode   String?   @map("service_code")
  invoices      Invoice[]
  licenses      License[]
  product       Product   @relation(fields: [productId], references: [id])

  @@map("plans")
}

model License {
  id                       String            @id @default(uuid())
  licenseKey               String            @unique @map("license_key")
  productId                String            @map("product_id")
  schoolName               String            @map("school_name")
  deviceLimit              Int               @map("device_limit")
  isUnlimited              Int               @map("is_unlimited")
  expiresAt                String            @map("expires_at")
  status                   String            @default("pending")
  isActive                 Int               @default(0) @map("is_active")
  planId                   String?           @map("plan_id")
  requestedSlug            String?           @map("requested_slug")
  wireguardIp              String?           @map("wireguard_ip")
  includeVpn               Int               @default(0) @map("include_vpn")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  activeHostname           String?           @map("active_hostname")
  activeOs                 String?           @map("active_os")
  appName                  String?           @map("app_name")
  customDomain             String?           @map("custom_domain")
  localPort                Int?              @map("local_port")
  operatorPhone            String?           @map("operator_phone")
  npsn                     String?           @map("npsn")
  requestedSupabaseAnonKey String?           @map("requested_supabase_anon_key")
  requestedSupabaseUrl     String?           @map("requested_supabase_url")
  originalDeviceId         String?           @map("original_device_id")
  lastHeartbeatAt          DateTime?         @map("last_heartbeat_at")
  deployMode               String?           @map("deploy_mode")
  activeUsers              Int?              @map("active_users")
  dbSize                   Float?            @map("db_size")
  memoryUsage              Float?            @map("memory_usage")
  lastTapped               DateTime?         @map("last_tapped")
  activatedDevices         ActivatedDevice[]
  logs                     ActivityLog[]
  invoices                 Invoice[]
  plan                     Plan?             @relation(fields: [planId], references: [id])
  product                  Product           @relation(fields: [productId], references: [id])
  subscriptions            Subscription[]

  @@map("licenses")
}

model ActivatedDevice {
  id          Int      @id @default(autoincrement())
  licenseId   String   @map("license_id")
  deviceId    String   @map("device_id")
  activatedAt DateTime @default(now()) @map("activated_at")
  license     License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, deviceId])
  @@map("activated_devices")
}

model Subscription {
  id         String   @id @default(uuid())
  licenseId  String   @map("license_id")
  schoolName String   @map("school_name")
  productId  String   @map("product_id")
  planId     String   @map("plan_id")
  status     String   @default("pending")
  startDate  String   @map("start_date")
  endDate    String   @map("end_date")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  license    License  @relation(fields: [licenseId], references: [id])

  @@map("subscriptions")
}

model Invoice {
  id                  String    @id @default(uuid())
  invoiceNumber       String    @unique @map("invoice_number")
  licenseId           String    @map("license_id")
  schoolName          String    @map("school_name")
  productId           String    @map("product_id")
  planTitle           String    @map("plan_title")
  amount              Float
  status              String    @default("unpaid")
  paymentMethod       String    @map("payment_method")
  paymentInstructions Json?     @map("payment_instructions")
  expiredTime         String    @map("expired_time")
  paidAt              DateTime? @map("paid_at")
  planId              String?   @map("plan_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  paymentProof        String?   @map("payment_proof")
  license             License   @relation(fields: [licenseId], references: [id])
  plan                Plan?     @relation(fields: [planId], references: [id])

  @@map("invoices")
}

model ActivityLog {
  id         String   @id @default(uuid())
  licenseKey String   @map("license_key")
  productId  String   @map("product_id")
  ipAddress  String   @map("ip_address")
  action     String
  createdAt  DateTime @default(now()) @map("created_at")
  license    License  @relation(fields: [licenseKey], references: [licenseKey])

  @@map("activity_logs")
}

model SystemSetting {
  key   String @id
  value String

  @@map("system_settings")
}

model TenantMetrics {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  activeUsers Int      @map("active_users")
  dbSize      Float    @map("db_size")
  memoryUsage Float    @map("memory_usage")
  lastTapped  DateTime @map("last_tapped")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("tenant_metrics")
}

model PlatformRisk {
  id                 String   @id @default(uuid())
  tenantId           String   @unique @map("tenant_id")
  riskScore          Int      @map("risk_score")
  riskLevel          String   @map("risk_level") // HEALTHY, WARNING, HIGH_RISK, CRITICAL
  emailFailureRate   Float    @map("email_failure_rate")
  paymentFailureRate Float    @map("payment_failure_rate")
  lastCalculatedAt   DateTime @map("last_calculated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("platform_risk")
}

model UpgradeIntelligence {
  id                 String   @id @default(uuid())
  tenantId           String   @unique @map("tenant_id")
  intentScore        Int      @map("intent_score")
  intentLevel        String   @map("intent_level") // LOW, MEDIUM, HIGH
  usageGrowthPercent Float?   @map("usage_growth_percent")
  lastCalculatedAt   DateTime @map("last_calculated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("upgrade_intelligence")
}

model SupportTicket {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  schoolName    String          @map("school_name")
  subject       String
  description   String
  status        String          @default("open") // open, answered, closed
  priority      String          @default("medium") // low, medium, high
  category      String          @default("TECHNICAL")
  rating        Int?
  ratingComment String?         @map("rating_comment")
  attachments   Json?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  messages      TicketMessage[]

  @@index([tenantId])
  @@map("support_tickets")
}

model TicketMessage {
  id          String        @id @default(uuid())
  ticketId    String        @map("ticket_id")
  sender      String        // tenant, agent
  senderName  String        @map("sender_name")
  message     String
  attachments Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

model WhatsAppLog {
  id           String   @id @default(uuid())
  recipient    String
  message      String
  status       String   // SENT, FAILED
  errorMessage String?  @map("error_message")
  triggerType  String   @map("trigger_type") // REGISTRATION_AWAL, MANUAL_RESEND, etc.
  productId    String?  @map("product_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("whatsapp_logs")
}


